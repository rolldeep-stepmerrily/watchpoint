NODE_ENV=local

# Ports
API_PORT=3000
WEB_PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/watchpoint

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Scraper
SCRAPER_USER_AGENT=WatchpointBot/0.1
SCRAPER_PATCH_CRON=0 */6 * * *
SCRAPER_REQUEST_DELAY_MS=2000

# Web
WEB_API_BASE_URL=http://localhost:3000
