NODE_ENV=local

# Ports
# 로컬은 API_PORT 사용. 프로덕션(Railway 등)은 PORT 환경 변수가 자동 주입됨.
API_PORT=3000
WEB_PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/watchpoint

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Scraper
SCRAPER_USER_AGENT=WatchpointBot/0.1
SCRAPER_PATCH_CRON=0 */6 * * *
SCRAPER_REQUEST_DELAY_MS=2000
# 프로덕션에서는 true. 로컬에서는 false로 두어 무분별한 외부 요청 차단.
SCRAPER_CRON_ENABLED=false

# Web
# Next.js 서버 컴포넌트가 API를 호출할 때의 base URL.
# 로컬: http://localhost:3000
# 프로덕션: Railway 서비스 URL (예: https://watchpoint-api-production.up.railway.app)
WEB_API_BASE_URL=http://localhost:3000

# 사이트 자체의 공개 URL (metadata canonical, sitemap, OpenGraph 등).
# 로컬: http://localhost:3001
# 프로덕션: Vercel URL (예: https://watchpoint.vercel.app) — trailing slash 없이.
WEB_PUBLIC_URL=http://localhost:3001

# MinIO (S3 호환 object storage) — 영웅/능력/특전 아이콘 호스팅용.
# `pnpm assets:upload` CLI가 apps/web/public/icons 전체를 업로드하고 DB iconUrl을 MINIO_PUBLIC_URL 기반으로 갱신.
# 로컬: docker-compose로 minio 추가하거나 비워두기 (CLI 미실행).
# 프로덕션: Railway MinIO 서비스의 API endpoint + access/secret + bucket 이름.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=watchpoint-icons
# 공개 객체 URL의 base. 없으면 MINIO_ENDPOINT 기반으로 path-style URL 생성.
# Railway 커스텀 도메인이나 CDN을 쓰면 `https://cdn.watchpoint.app` 같은 형태로 지정.
MINIO_PUBLIC_URL=

# Sentry — 에러 트래커. 비어있으면 init 스킵 (silent).
# API는 Railway, Web은 Vercel env에 설정. local에서는 보통 비워둠.
# DSN은 public 가능하나 env로 분리하면 환경별/회사별 분리 용이.
SENTRY_DSN=
# Web client에 inline되는 변수 (NEXT_PUBLIC_ prefix 필수). Vercel env에 설정.
NEXT_PUBLIC_SENTRY_DSN=
