NODE_ENV=local

# Ports
# 로컬은 API_PORT 사용. 프로덕션(Railway 등)은 PORT 환경 변수가 자동 주입됨.
API_PORT=3000
WEB_PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/watchpoint

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Scraper
SCRAPER_USER_AGENT=WatchpointBot/0.1
SCRAPER_PATCH_CRON=0 */6 * * *
SCRAPER_REQUEST_DELAY_MS=2000
# 프로덕션에서는 true. 로컬에서는 false로 두어 무분별한 외부 요청 차단.
SCRAPER_CRON_ENABLED=false

# Web
# Next.js 서버 컴포넌트가 API를 호출할 때의 base URL.
# 로컬: http://localhost:3000
# 프로덕션: Railway 서비스 URL (예: https://watchpoint-api-production.up.railway.app)
WEB_API_BASE_URL=http://localhost:3000

# 사이트 자체의 공개 URL (metadata canonical, sitemap, OpenGraph 등).
# 로컬: http://localhost:3001
# 프로덕션: Vercel URL (예: https://watchpoint.vercel.app) — trailing slash 없이.
WEB_PUBLIC_URL=http://localhost:3001

# MinIO (S3 호환 object storage) — 영웅/능력/특전 아이콘 호스팅용.
# `pnpm assets:upload` CLI가 apps/web/public/icons 전체를 업로드하고 DB iconUrl을 MINIO_PUBLIC_URL 기반으로 갱신.
# 로컬: docker-compose로 minio 추가하거나 비워두기 (CLI 미실행).
# 프로덕션: Railway MinIO 서비스의 API endpoint + access/secret + bucket 이름.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=watchpoint-icons
# 공개 객체 URL의 base. 없으면 MINIO_ENDPOINT 기반으로 path-style URL 생성.
# Railway 커스텀 도메인이나 CDN을 쓰면 `https://cdn.watchpoint.app` 같은 형태로 지정.
MINIO_PUBLIC_URL=

# OverFast API (전적조회 베타). 기본값은 TeKrop의 public 인스턴스.
# 트래픽 증가 시 Docker로 self-host한 인스턴스 URL로 교체 가능 (env만 변경, 코드 수정 불필요).
# https://github.com/TeKrop/overfast-api
OVERFAST_API_BASE_URL=https://overfast-api.tekrop.fr

# Monitoring (외부 routine이 결과 적재 시 사용하는 scoped token).
# 32바이트 이상 랜덤 추천: `openssl rand -base64 32`.
# 비어있으면 /internal/monitoring-log 전체가 차단 (운영자가 키 누락을 빠르게 인지).
MONITORING_INGEST_KEY=

# Auth — JWT 시크릿 (각각 32바이트 이상 랜덤). access는 짧게, refresh는 길게.
# `openssl rand -base64 32` 2번 실행해서 서로 다른 값 사용.
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
# refresh_tokens 테이블에 저장되는 DB row의 expiresAt 기준. JWT_REFRESH_EXPIRES_IN과 일치시켜야 함.
REFRESH_TOKEN_TTL_DAYS=7

# GitHub OAuth (선택). 비워두면 부팅은 되지만 /auth/github 라우트 호출 시 GitHub가 reject.
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL은 GITHUB_CALLBACK_URL과 동일하게 설정.
# 로컬: http://localhost:3000/auth/github/callback
# 프로덕션: https://api.o-watchpoint.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Sentry — 에러 트래커. 비어있으면 init 스킵 (silent).
# API는 Railway, Web은 Vercel env에 설정. local에서는 보통 비워둠.
# DSN은 public 가능하나 env로 분리하면 환경별/회사별 분리 용이.
SENTRY_DSN=
# Web client에 inline되는 변수 (NEXT_PUBLIC_ prefix 필수). Vercel env에 설정.
NEXT_PUBLIC_SENTRY_DSN=
