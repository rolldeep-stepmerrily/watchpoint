{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@@cache": ["src/common/cache/index"],
      "@@cqrs": ["src/common/cqrs/index"],
      "@@db": ["src/common/prisma/index"],
      "@@decorators": ["src/common/decorators/index"],
      "@@entities": ["src/common/entities/index"],
      "@@exceptions": ["src/common/exceptions/index"],
      "@@prisma": ["src/generated/prisma/client"],
      "@@redis": ["src/common/redis/index"],
      "@@shared": ["../../packages/shared/src/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/generated"]
}
