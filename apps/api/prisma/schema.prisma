generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Hero {
  id                       Int       @id @default(autoincrement())
  codename                 String    @unique
  name                     String
  nameTranslations         Json?
  role                     HeroRole
  subrole                  Subrole
  releasedAt               DateTime
  portraitUrl              String?
  description              String?
  descriptionTranslations  Json?
  sourceUrl                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime? @updatedAt

  stat          HeroStat?
  abilities     HeroAbility[]
  perks         HeroPerk[]
  statRevisions HeroStatRevision[]
  patchEntries  PatchNoteEntry[]
  changeLogs    HeroChangeLog[]

  @@index([role])
  @@map("heroes")
}

model HeroStat {
  id        Int       @id @default(autoincrement())
  heroId    Int       @unique
  health    Int
  armor     Int       @default(0)
  shield    Int       @default(0)
  moveSpeed Float
  extras    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  hero Hero @relation(fields: [heroId], references: [id], onDelete: Cascade)

  @@map("hero_stats")
}

model HeroAbility {
  id                       Int          @id @default(autoincrement())
  heroId                   Int
  slot                     AbilitySlot
  key                      String?
  /// Blizzard 페이지의 ability id (예: "fusion-cannons"). 한국어 sync 시 매칭 결과로 채워지고,
  /// 영문 sync에서 동일 id로 ability를 식별해 다국어 데이터를 안전하게 병합한다.
  blizzardId               String?
  name                     String
  nameTranslations         Json?
  description              String
  descriptionTranslations  Json?
  stats                    Json?
  iconUrl                  String?
  order                    Int          @default(0)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime?    @updatedAt

  hero Hero @relation(fields: [heroId], references: [id], onDelete: Cascade)

  @@unique([heroId, slot, order])
  @@index([heroId])
  @@index([heroId, blizzardId])
  @@map("hero_abilities")
}

model HeroPerk {
  id                       Int       @id @default(autoincrement())
  heroId                   Int
  tier                     PerkTier
  slot                     Int
  name                     String
  nameTranslations         Json?
  description              String
  descriptionTranslations  Json?
  stats                    Json?
  iconUrl                  String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime? @updatedAt

  hero         Hero             @relation(fields: [heroId], references: [id], onDelete: Cascade)
  patchEntries PatchNoteEntry[]

  @@unique([heroId, tier, slot])
  @@index([heroId])
  @@map("hero_perks")
}

model HeroStatRevision {
  id          Int      @id @default(autoincrement())
  heroId      Int
  patchNoteId Int
  diff        Json
  appliedAt   DateTime @default(now())

  hero      Hero      @relation(fields: [heroId], references: [id], onDelete: Cascade)
  patchNote PatchNote @relation(fields: [patchNoteId], references: [id], onDelete: Cascade)

  @@index([heroId, appliedAt])
  @@index([patchNoteId])
  @@map("hero_stat_revisions")
}

model PatchNote {
  id                  Int              @id @default(autoincrement())
  version             String           @unique
  title               String
  titleTranslations   Json?
  releasedAt          DateTime
  sourceUrl           String           @unique
  summary             String?
  summaryTranslations Json?
  status              PatchNoteStatus  @default(DRAFT)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime?        @updatedAt

  entries       PatchNoteEntry[]
  statRevisions HeroStatRevision[]

  @@index([releasedAt])
  @@index([status])
  @@map("patch_notes")
}

model PatchNoteEntry {
  id                  Int           @id @default(autoincrement())
  patchNoteId         Int
  category            EntryCategory
  heroId              Int?
  perkId              Int?
  title               String
  titleTranslations   Json?
  body                String
  bodyTranslations    Json?
  order               Int           @default(0)
  createdAt           DateTime      @default(now())

  patchNote PatchNote @relation(fields: [patchNoteId], references: [id], onDelete: Cascade)
  hero      Hero?     @relation(fields: [heroId], references: [id], onDelete: SetNull)
  perk      HeroPerk? @relation(fields: [perkId], references: [id], onDelete: SetNull)

  @@index([patchNoteId, order])
  @@index([heroId])
  @@index([perkId])
  @@map("patch_note_entries")
}

model ScrapeJob {
  id          Int           @id @default(autoincrement())
  source      ScrapeSource
  target      String
  status      ScrapeStatus
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  error       String?
  diffSummary Json?

  changeLogs HeroChangeLog[]

  @@index([source, startedAt])
  @@index([status])
  @@map("scrape_jobs")
}

/// 영웅 데이터(stats/abilities/perks) 자동 sync 시 발견된 변경 사항 audit log.
/// 디버그/추적용 — 비즈니스 로직은 이 테이블을 읽지 않음.
model HeroChangeLog {
  id          Int            @id @default(autoincrement())
  heroId      Int
  scrapeJobId Int?
  changeType  HeroChangeType
  /// 'hero' | 'ability' | 'perk' | 'stat' 등의 대상 분류
  target      String
  /// 식별자 — ability slot, perk "tier-slot", stat key 등 (없으면 null)
  targetKey   String?
  before      Json?
  after       Json?
  createdAt   DateTime       @default(now())

  hero      Hero       @relation(fields: [heroId], references: [id], onDelete: Cascade)
  scrapeJob ScrapeJob? @relation(fields: [scrapeJobId], references: [id], onDelete: SetNull)

  @@index([heroId, createdAt])
  @@index([changeType])
  @@index([scrapeJobId])
  @@map("hero_change_logs")
}

enum HeroRole {
  TANK
  DAMAGE
  SUPPORT
}

enum PerkTier {
  MINOR
  MAJOR
}

enum Subrole {
  Bruiser
  Initiator
  Stalwart
  Sharpshooter
  Flanker
  Specialist
  Recon
  Tactician
  Medic
  Survivor
}

enum AbilitySlot {
  PASSIVE
  PRIMARY
  SECONDARY
  ABILITY_1
  ABILITY_2
  ULTIMATE
}

enum PatchNoteStatus {
  DRAFT
  PUBLISHED
  PENDING_REVIEW
}

enum EntryCategory {
  HERO_BALANCE
  BUG_FIX
  MAP
  SYSTEM
  GENERAL
}

enum ScrapeSource {
  BLIZZARD_PATCH_NOTES
  BLIZZARD_PATCH_NOTES_EN
  BLIZZARD_HERO_EN
  BLIZZARD_HERO_KO
  /// @deprecated 나무위키 출처 제거됨. 기존 ScrapeJob row 호환을 위해 enum value만 유지.
  NAMUWIKI_HERO
}

enum HeroChangeType {
  HERO_STAT_CHANGED
  ABILITY_ADDED
  ABILITY_REMOVED
  ABILITY_NAME_CHANGED
  ABILITY_DESCRIPTION_CHANGED
  ABILITY_STATS_CHANGED
  PERK_ADDED
  PERK_REMOVED
  PERK_NAME_CHANGED
  PERK_DESCRIPTION_CHANGED
}

enum ScrapeStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

/// 회원 계정. 이메일/비밀번호 로그인 + GitHub OAuth 모두 동일 User 행을 공유.
/// password가 null이면 OAuth 전용 계정 (이메일/비번 로그인 불가).
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String?
  name      String?
  avatarUrl String?
  role      UserRole  @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  oauthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

/// 외부 OAuth provider 연동 정보. 같은 provider+providerAccountId 조합은 1행.
/// accessToken은 GitHub API 호출용 (현재는 저장만, 미사용).
model OAuthAccount {
  id                Int       @id @default(autoincrement())
  userId            Int
  provider          String
  providerAccountId String
  accessToken       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

/// 발급된 refresh token 화이트리스트. logout 시 삭제 → 재사용 차단.
model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// 전적조회 베타 호출 audit log. 상세 수치는 저장하지 않고 요청 메타(IP/requestId/query/성공여부)만 기록.
/// 운영적으로 OverFast 의존도/오남용을 추적하기 위한 용도.
model CareerLookupLog {
  id        BigInt              @id @default(autoincrement())
  requestId String
  eventType CareerLookupEvent
  /// SEARCH: q 쿼리, SUMMARY|STATS: playerId (BattleTag 그대로 — `-`는 #로 치환 가능)
  query     String
  /// X-Forwarded-For 우선, 없으면 socket.remoteAddress. raw 그대로 저장.
  ip        String
  success   Boolean
  /// 실패 시 AppException.errorCode (예: CAREER_NOT_FOUND, CAREER_UPSTREAM_UNAVAILABLE)
  errorCode String?
  createdAt DateTime            @default(now())

  @@index([createdAt])
  @@index([ip, createdAt])
  @@index([eventType, createdAt])
  @@map("career_lookup_logs")
}

enum CareerLookupEvent {
  SEARCH
  SUMMARY
  STATS
}

/// 외부 모니터링 routine (예: Claude /schedule prod-smoke) 결과 적재용.
/// 운영자가 장기 trend 분석(월별 fail 횟수, transient 비율 등)에 활용한다.
/// 호출은 /internal/monitoring-log endpoint에 scoped token (MONITORING_INGEST_KEY)으로 인증.
model MonitoringLog {
  id         Int      @id @default(autoincrement())
  runAt      DateTime @default(now())
  /// "prod-smoke" 등. 추후 다른 monitoring 타입 확장 대비.
  kind       String
  /// "pass" | "fail" | "transient"
  status     String
  total      Int
  passed     Int
  failed     Int
  durationMs Int?
  /// fix PR을 만들었으면 URL. 없으면 null.
  fixPrUrl   String?
  /// 짧은 요약 (실패 원인, transient 사유 등). 본문 trace는 저장하지 않음.
  notes      String?

  @@index([kind, runAt(sort: Desc)])
  @@map("monitoring_logs")
}
