{
  "name": "@watchpoint/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "prisma generate && nest start --watch",
    "start": "node dist/main",
    "start:prod": "prisma migrate deploy && node dist/main",
    "lint": "biome lint src/",
    "check": "biome check --write src/",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "patch:sync": "ts-node -r tsconfig-paths/register src/cli/main.ts patch:sync",
    "patch:sync:en": "ts-node -r tsconfig-paths/register src/cli/main.ts patch:sync:en",
    "patch:backfill": "ts-node -r tsconfig-paths/register src/cli/main.ts patch:backfill",
    "patch:list": "ts-node -r tsconfig-paths/register src/cli/main.ts patch:list",
    "patch:review": "ts-node -r tsconfig-paths/register src/cli/main.ts patch:review",
    "hero:sync": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync",
    "hero:sync:all": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync:all",
    "hero:sync:en": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync:en",
    "hero:sync:en:all": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync:en:all",
    "hero:sync:ko": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync:ko",
    "hero:sync:ko:all": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:sync:ko:all",
    "hero:edit": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:edit",
    "hero:perks:edit": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:perks:edit",
    "hero:icons:download": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:icons:download",
    "hero:icons:download:all": "ts-node -r tsconfig-paths/register src/cli/main.ts hero:icons:download:all"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@scalar/nestjs-api-reference": "^0.5.1",
    "@watchpoint/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "domhandler": "^6.0.1",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "joi": "^17.13.3",
    "nest-commander": "^3.16.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "undici": "^6.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "dotenv": "^16.4.0",
    "jest": "^29.5.0",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@@cqrs$": "<rootDir>/common/cqrs/index",
      "^@@db$": "<rootDir>/common/prisma/index",
      "^@@decorators$": "<rootDir>/common/decorators/index",
      "^@@entities$": "<rootDir>/common/entities/index",
      "^@@exceptions$": "<rootDir>/common/exceptions/index",
      "^@@prisma$": "<rootDir>/generated/prisma/client",
      "^@@redis$": "<rootDir>/common/redis/index",
      "^@@shared$": "<rootDir>/../../../packages/shared/src/index",
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}
